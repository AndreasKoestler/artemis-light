# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# IDE / editor configs
.idea/
.vscode/

# Local agent settings
.claude/

# Environment files — never commit credentials
.env
.env.*

# Local SQLite databases (e.g. from the persistence example)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Coverage reports (generated by cargo-llvm-cov for the SonarQube scan)
lcov.info

# Rust quality analysis: generated iteration store + consolidated report
.rust-quality/

# SonarQube: local scanner working dir and machine-local project config
.scannerwork/
sonar-project.properties

# Local qrspi pipeline state
.qrspi/

# Git worktrees for isolated feature work
.worktrees/

# Superpowers docs (local, not committed)
docs/superpowers
